## Runtime database URL (recommended for Vercel/serverless)
# Supabase Transaction pooler (6543) + ssl + pgbouncer flags:
# DATABASE_URL="postgresql://postgres.<project-ref>:<PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
DATABASE_URL=""

## Direct database URL (recommended for Prisma CLI: db push / migrations)
# Supabase direct (5432) + ssl:
# DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL=""

